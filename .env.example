# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API (para o robô)
ANTHROPIC_API_KEY=your-anthropic-api-key

# NewsAPI (opcional — 80k fontes)
NEWS_API_KEY=your-newsapi-key

# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=NewsBot
NEXT_PUBLIC_DEFAULT_LANG=pt

# Admin (email do admin principal)
ADMIN_EMAIL=halderleal.usa@gmail.com

# Cron secret (para proteger endpoint do robô)
CRON_SECRET=your-random-secret-here
